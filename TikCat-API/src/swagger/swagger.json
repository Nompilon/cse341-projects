{
  "swagger": "2.0",
  "info": {
    "title": "TikCat API Documentation",
    "version": "1.0.0",
    "description": "API documentation for TikCat, a ticketing platform built with Node.js, Express, MongoDB, Passport.js, and JWT authentication."
  },
  "host": "localhost:3000",
  "basePath": "/",
  "schemes": [
    "http"
  ],
  "securityDefinitions": {
    "BearerAuth": {
      "type": "apiKey",
      "in": "header",
      "name": "Authorization",
      "description": "Enter JWT token as: 'Bearer' + JW Token "
    }
  },
  "paths": {
    "/health": {
      "get": {
        "description": "",
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    }
  },
  "definitions": {
    "RegisterRequest": {
      "type": "object",
      "properties": {
        "firstName": {
          "type": "string",
          "example": "John"
        },
        "lastName": {
          "type": "string",
          "example": "Doe"
        },
        "email": {
          "type": "string",
          "example": "john@example.com"
        },
        "password": {
          "type": "string",
          "example": "Password123"
        }
      }
    },
    "LoginRequest": {
      "type": "object",
      "properties": {
        "email": {
          "type": "string",
          "example": "john@example.com"
        },
        "password": {
          "type": "string",
          "example": "Password123"
        }
      }
    },
    "User": {
      "type": "object",
      "properties": {
        "_id": {
          "type": "string",
          "example": "68459f7e1a2f123456789abc"
        },
        "firstName": {
          "type": "string",
          "example": "John"
        },
        "lastName": {
          "type": "string",
          "example": "Doe"
        },
        "email": {
          "type": "string",
          "example": "john@example.com"
        },
        "role": {
          "type": "string",
          "example": "attendee"
        },
        "profileImage": {
          "type": "string",
          "example": "/public/images/profile.jpg"
        },
        "phoneNumber": {
          "type": "string",
          "example": "+243812345678"
        }
      }
    },
    "Category": {
      "type": "object",
      "properties": {
        "_id": {
          "type": "string",
          "example": "68459f7e1a2f123456789abc"
        },
        "name": {
          "type": "string",
          "example": "Technology"
        },
        "description": {
          "type": "string",
          "example": "Technology related events"
        }
      }
    },
    "Venue": {
      "type": "object",
      "properties": {
        "_id": {
          "type": "string",
          "example": "68459f7e1a2f123456789abc"
        },
        "name": {
          "type": "string",
          "example": "Kin Plaza"
        },
        "address": {
          "type": "string",
          "example": "Boulevard du 30 Juin"
        },
        "city": {
          "type": "string",
          "example": "Kinshasa"
        },
        "capacity": {
          "type": "number",
          "example": 500
        },
        "contactPhone": {
          "type": "string",
          "example": "+243812345678"
        }
      }
    },
    "Event": {
      "type": "object",
      "properties": {
        "_id": {
          "type": "string",
          "example": "68459f7e1a2f123456789abc"
        },
        "title": {
          "type": "string",
          "example": "Tech Summit 2026"
        },
        "description": {
          "type": "string",
          "example": "Annual technology conference"
        },
        "categoryId": {
          "type": "string",
          "example": "68459f7e1a2f123456789abc"
        },
        "venueId": {
          "type": "string",
          "example": "68459f7e1a2f123456789abc"
        },
        "organizerId": {
          "type": "string",
          "example": "68459f7e1a2f123456789abc"
        },
        "eventDate": {
          "type": "string",
          "example": "2026-07-15T10:00:00.000Z"
        },
        "startTime": {
          "type": "string",
          "example": "10:00"
        },
        "endTime": {
          "type": "string",
          "example": "17:00"
        },
        "ticketPrice": {
          "type": "number",
          "example": 50
        },
        "totalTickets": {
          "type": "number",
          "example": 500
        },
        "availableTickets": {
          "type": "number",
          "example": 500
        },
        "status": {
          "type": "string",
          "example": "Published"
        }
      }
    },
    "Ticket": {
      "type": "object",
      "properties": {
        "_id": {
          "type": "string",
          "example": "68459f7e1a2f123456789abc"
        },
        "eventId": {
          "type": "string",
          "example": "68459f7e1a2f123456789abc"
        },
        "attendeeId": {
          "type": "string",
          "example": "68459f7e1a2f123456789abc"
        },
        "ticketCode": {
          "type": "string",
          "example": "AB12CD34EF56"
        },
        "qrCode": {
          "type": "string",
          "example": "data:image/png;base64,..."
        },
        "status": {
          "type": "string",
          "example": "Paid"
        }
      }
    },
    "Order": {
      "type": "object",
      "properties": {
        "_id": {
          "type": "string",
          "example": "68459f7e1a2f123456789abc"
        },
        "userId": {
          "type": "string",
          "example": "68459f7e1a2f123456789abc"
        },
        "eventId": {
          "type": "string",
          "example": "68459f7e1a2f123456789abc"
        },
        "quantity": {
          "type": "number",
          "example": 2
        },
        "totalAmount": {
          "type": "number",
          "example": 100
        },
        "paymentStatus": {
          "type": "string",
          "example": "Paid"
        }
      }
    }
  }
}